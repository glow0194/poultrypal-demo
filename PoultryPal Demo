 /* Modal Styles */
.modal {
  display: none; 
  position: fixed; 
  z-index: 1; 
  padding-top: 60px; 
  left: 0;
  top: 0;
  width: 100%; 
  height: 100%; 
  overflow: auto; 
  background-color: rgba(0,0,0,0.4);
}
.modal-content {
  background-color: #fff8dc;
  margin: 5% auto;
  padding: 20px;
  border-radius: 10px;
  width: 80%;
  max-width: 400px;
}
.close {
  color: #333;
  float: right;
  font-size: 28px;
  font-weight: bold;
  cursor: pointer;
}
.close:hover {
  color: red;
}

js/script.js

function showScreen(feature) {
    const screen = document.getElementById('screen');
    screen.innerHTML = ''; // Clear previous content

    switch(feature) {
        case 'feed':
            screen.innerHTML = <h2>Feed Entry</h2><p>Enter feed quantity and cost here.</p>;
            break;
        case 'mortality':
            screen.innerHTML = <h2>Mortality Entry</h2><p>Record daily bird mortality here.</p>;
            break;
        case 'health':
            screen.innerHTML = <h2>Health Checker</h2><p>Input symptoms to get disease suggestions.</p>;
            break;
        case 'vaccine':
            screen.innerHTML = <h2>Vaccination Tracker</h2><p>Track vaccination schedules and alerts.</p>;
            break;
        case 'vet':
        openModal('vetModal');
            break;
        case 'drugs':
            openModal('drugsModal');
            break;
        default:
            screen.innerHTML = <p>Click a button above to explore a feature!</p>;
    }
}

// Modal Functions
function openModal(id) {
    document.getElementById(id).style.display = "block";
}

function closeModal(id) {
    document.getElementById(id).style.display = "none";
}

// Close modal when clicking outside
window.onclick = function(event) {
    const vetModal = document.getElementById('vetModal');
    const drugsModal = document.getElementById('drugsModal');
    if (event.target == vetModal) vetModal.style.display = "none";
    if (event.target == drugsModal) drugsModal.style.display = "none";
}
